{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": ["./lua/?.lua", "./lua/?/init.lua"]
  },
  "workspace": {
    "library": [
      "${env:WEZTERM_LUA_TYPES}",
      "${env:NVIM_PLENARY_LIB}",
      "${3rd}/luv/library"
    ]
  },
  "diagnostics": {
    "globals": ["utf8"]
  }
}
