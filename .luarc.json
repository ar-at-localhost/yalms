{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": ["./lua/?.lua", "./lua/?/init.lua"]
  },
  "workspace": {
    "library": [
      "${env:NVIM_SNACKS_LUA_TYPES}",
      "${env:ORGMODE_LUA_TYPES}",
      "${env:NVIM_PLENARY_LIB}",
      "${env:WEZTERM_LUA_TYPES}",
      "${env:VIMRUNTIME}/lua",
      "${3rd}/luv/library",
      "${3rd}/busted/library",
      "${3rd}/plenary/library"
    ]
  },
  "diagnostics": {
    "globals": ["describe", "it", "_G", "utf8"]
  }
}
